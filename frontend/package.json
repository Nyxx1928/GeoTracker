{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.13.2",
    "clsx": "^1.2.1",
    "maplibre-gl": "^4.7.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^4.11.0",
    "react-router-dom": "^7.11.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@eslint/js": "8.57.1",
    "autoprefixer": "^10.4.18",
    "eslint": "8.57.1",
    "eslint-config-react-app": "7.0.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "4.9.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "env": {
      "browser": true,
      "node": true,
      "jest": true
    },
    "settings": {
      "react": {
        "version": "detect"
      }
    },
    "rules": {
      "react/react-in-jsx-scope": "off",
      "react/prop-types": "off"
    },
    "overrides": [
      {
        "files": ["**/*.test.js", "**/*.spec.js", "**/__tests__/**"],
        "env": { "jest": true }
      },
      {
        "files": ["postcss.config.js", "tailwind.config.js", "webpack.config.js", "craco.config.js"],
        "env": { "node": true }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
