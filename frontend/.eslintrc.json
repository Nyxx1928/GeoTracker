{
  "extends": [
    "react-app",
    "react-app/jest"
  ],
  "env": {
    "browser": true,
    "node": true,
    "jest": true
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "react/prop-types": "off"
  },
  "overrides": [
    {
      "files": ["**/*.test.js", "**/*.spec.js", "**/__tests__/**"],
      "env": { "jest": true }
    },
    {
      "files": ["postcss.config.js", "tailwind.config.js", "webpack.config.js", "craco.config.js"],
      "env": { "node": true }
    }
  ]
}
